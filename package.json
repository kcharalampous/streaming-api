{
  "name": "streaming-api",
  "version": "1.0.0",
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "concurrently \"nodemon\" \"nodemon -x 'bun run tsoa'\"",
    "start": "bun src/server.ts",
    "build": "bun run tsoa && tsc",
    "tsoa": "tsoa spec-and-routes",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "check": "biome check ./src",
    "lint": "biome lint ./src",
    "format": "biome format ./src --write"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@scalar/express-api-reference": "^0.9.4",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "tsoa": "^7.0.0-alpha.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "prisma": "^7.5.0",
    "typescript": "^5.8.0"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "@prisma/client",
    "@prisma/engines",
    "prisma"
  ]
}
